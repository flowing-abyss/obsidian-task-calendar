{
  "name": "obsidian-task-calendar",
  "version": "1.2.0",
  "description": "Flexible Task Calendar plugin for Obsidian",
  "main": "main.js",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "postversion": "git push origin master && git push origin --tags",
    "test": "npm run review:obsidian && npm run test:unit",
    "test:unit": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "review:obsidian": "npm run review:obsidian:code && npm run review:obsidian:metadata",
    "review:obsidian:code": "eslint --config eslint.obsidian.config.mjs src",
    "review:obsidian:metadata": "eslint --config eslint.obsidian.metadata.config.mjs --no-error-on-unmatched-pattern manifest.json package.json LICENSE",
    "review:local": "npm run review:obsidian && npm run lint && npm audit --audit-level=moderate && npm run build && npm run test:unit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "calendar",
    "tasks"
  ],
  "author": "flowing-abyss",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "10.0.1",
    "@eslint/json": "2.0.0",
    "@types/jsdom": "28.0.3",
    "@types/node": "26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "esbuild": "0.28.1",
    "eslint": "10.5.0",
    "eslint-plugin-depend": "1.5.0",
    "eslint-plugin-obsidianmd": "0.3.0",
    "eslint-plugin-sonarjs": "4.1.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "knip": "6.17.2",
    "obsidian-test-mocks": "3.3.0",
    "prettier": "3.8.4",
    "prettier-plugin-organize-imports": "4.3.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "obsidian": "1.13.1"
  }
}
